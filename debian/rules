#!/usr/bin/make -f

%:
	dh $@ --parallel

override_dh_auto_configure:
	dh_auto_configure -- \
		-DCMAKE_BUILD_TYPE=Release \
		-DOPT_ENABLE_QT6=ON \
		-DVERSION=$(DEB_VERSION_UPSTREAM)

override_dh_shlibdeps:
	dh_shlibdeps --dpkg-shlibdeps-params=--warnings=0

override_dh_install:
	dh_install

override_dh_glib:
	dh_glib
